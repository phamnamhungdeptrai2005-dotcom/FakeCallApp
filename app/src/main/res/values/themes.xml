<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FakeCall" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/call_text_secondary</item>
    </style>

    <!-- Full-screen call theme (no status bar) -->
    <style name="Theme.FakeCall.Call" parent="Theme.FakeCall">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/call_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
