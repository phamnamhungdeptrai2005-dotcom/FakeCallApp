<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/call_bg">

    <!-- Blurred/gradient background overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/call_gradient_bg" />

    <!-- Top section: caller info -->
    <LinearLayout
        android:id="@+id/layoutCallerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="80dp"
        android:paddingHorizontal="32dp">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivCallerAvatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_person_placeholder"
            android:layout_marginBottom="24dp" />

        <!-- Caller name -->
        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown"
            android:textColor="@color/call_text_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- "Incoming call" label -->
        <TextView
            android:id="@+id/tvIncomingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/incoming_call_label"
            android:textColor="@color/call_text_secondary"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Bottom action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:paddingHorizontal="40dp">

        <!-- Decline -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnDecline"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_call_end"
                android:background="@drawable/circle_red_bg"
                android:contentDescription="Decline"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decline"
                android:textColor="@color/call_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Answer -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAnswer"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_call"
                android:background="@drawable/circle_green_bg"
                android:contentDescription="Answer"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Answer"
                android:textColor="@color/call_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Ripple / pulse animation around avatar (decorative ring) -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="60dp"
        android:layout_centerHorizontal="true"
        android:background="@drawable/pulse_ring"
        android:alpha="0.3" />

</RelativeLayout>
